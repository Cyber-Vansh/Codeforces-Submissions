t = int(input())
for _ in range(t):
    n = int(input())
    arr = list(map(int,input().split()))
 
    d = {}
 
    for i in arr:
        if i in d:
            d[i]+=1
        else:
            d[i]=1
    ans = "NO"
    for i,j in d.items():
        if j>1:
            ans = "YES"
 
    print(ans)