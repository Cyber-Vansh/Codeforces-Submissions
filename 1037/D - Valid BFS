from collections import deque
 
n = int(input())
tree = [[] for i in range(n+1)]
for i in range(n-1):
    u,v = map(int,input().split())
 
    tree[u].append(v)
    tree[v].append(u)
 
sequence = list(map(int,input().split()))
 
order = [None]*(n+1)
for i in range(n):
    order[sequence[i]]=i+1
 
for i in range(1,n+1):
    new = []
    for j in tree[i]:
        if order[j]>order[i]:
            new.append((order[j],j))
    new.sort()
    tree[i] = new
 
bfs = [1]
 
de = deque([1])
 
while de:
    node = de.popleft()
 
    for o,curr in tree[node]:
        bfs.append(curr)
        de.append(curr)
 
if bfs==sequence:
    print("Yes")
else:
    print("No")